# =============================================================================
#  Chatterbox — Docker Compose Environment Variables
#  Copy this file to .env and fill in your own values:
#    cp .env.example .env
#
#  .env is listed in .gitignore and will NEVER be committed.
#  This file (.env.example) IS committed — it shows which variables are needed.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
# Public URL of the application (used for CORS whitelist)
CLIENT_URL=

# Extra allowed CORS origins — comma-separated, no spaces.
# RFC-1918 private IPs (192.168.x.x, 10.x.x.x, 172.16-31.x.x) and localhost
# are always allowed automatically. Use this only for additional public origins.
# Example: CORS_ORIGINS=https://myapp.example.com,http://192.168.1.50:3000
CORS_ORIGINS=

# Host port to expose the app on (nginx)
APP_PORT=80

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Root admin credentials for the MongoDB container
MONGO_ROOT_USERNAME=chatterbox_admin
MONGO_ROOT_PASSWORD=change_me_strong_mongo_password

# Database name
MONGO_DB=chatterboxdb

# Host port to expose MongoDB on (optional, for local tooling access)
MONGO_PORT=27017

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_strong_redis_password

# Host port to expose Redis on
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with:
#   openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32_at_least_32_chars
JWT_REFRESH_SECRET=change_me_generate_another_openssl_rand_hex_32_secret

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── MinIO (S3-compatible file storage) ───────────────────────────────────────
# MinIO root credentials (also used as the S3 access/secret key pair)
MINIO_ACCESS_KEY=chatterbox_minio
MINIO_SECRET_KEY=change_me_strong_minio_secret_key

# Bucket name for file uploads
MINIO_BUCKET=chatterbox-uploads

# Host ports to expose MinIO on (S3 API and web console)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window per IP
RATE_LIMIT_MAX=10000

# ── File Upload ───────────────────────────────────────────────────────────────
# Max file size in bytes (default: 25 MB)
MAX_FILE_SIZE=26214400

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info


# ── NGROK ───────────────────────────────────────────────────────────────────
NGROK_AUTHTOKEN=change_me_ngrok_authtoken_from_ngrok_dashboard

# ── LiveKit (WebRTC SFU — multi-server) ───────────────────────────────────────
# API key/secret pair — shared across all LiveKit servers.
# Used by backend to generate access tokens.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Number of LiveKit servers (must match docker-compose livekit1..N services)
# Backend round-robin selects a server; Nginx routes /livekit/<id>/ to it.
LIVEKIT_SERVER_COUNT=2

