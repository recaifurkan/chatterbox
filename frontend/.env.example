# =============================================================================
#  Chatterbox Frontend — Environment Variables
#  Copy this file to .env and adjust if needed:
#    cp .env.example .env
#
#  ┌─ Docker Compose / Nginx ──────────────────────────────────────────────┐
#  │  VITE_API_URL=/api/v1        (nginx proxies /api → backend)           │
#  │  VITE_SOCKET_URL=            (empty → connects to same origin)        │
#  │  VITE_BACKEND_URL=           (not used in Docker mode)                │
#  └───────────────────────────────────────────────────────────────────────┘
#
#  ┌─ Local development (npm run dev) ─────────────────────────────────────┐
#  │  Vite proxy'si /api ve /socket.io isteklerini backend'e yönlendirir.  │
#  │  Relative URL + Vite proxy = CORS sorunu tamamen ortadan kalkar.       │
#  │  Aynı ağdaki başka cihazlardan http://<IP>:3000 ile erişilebilir.     │
#  │                                                                        │
#  │  VITE_API_URL=/api/v1                                                  │
#  │  VITE_SOCKET_URL=                                                      │
#  │  VITE_BACKEND_URL=http://localhost:5000   (Vite proxy hedefi)         │
#  └───────────────────────────────────────────────────────────────────────┘
# =============================================================================

# Base URL for REST API calls
VITE_API_URL=/api/v1

# Socket.IO server URL — leave empty to connect to same origin (recommended)
VITE_SOCKET_URL=

# Vite proxy target — backend address as seen FROM the Vite server machine.
# Change to http://192.168.x.x:5000 if backend runs on a different machine.
# Not used in Docker Compose mode.
VITE_BACKEND_URL=http://localhost:5000
