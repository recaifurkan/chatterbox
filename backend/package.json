{
  "name": "chatterbox-backend",
  "version": "1.0.0",
  "description": "Chatterbox — real-time chat backend with Node.js, Express, Socket.IO, and Redis",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint src/ --ext .js",
    "test": "jest --runInBand --forceExit --testTimeout=30000",
    "test:coverage": "jest --coverage --runInBand --forceExit --testTimeout=30000",
    "test:unit": "jest --runInBand --forceExit --testTimeout=30000 tests/unit/",
    "test:integration": "jest --runInBand --forceExit --testTimeout=30000 tests/integration/"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/config/**",
      "!src/utils/logger.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "branches": 70,
        "functions": 80,
        "statements": 80
      }
    },
    "coverageReporters": ["text", "lcov", "html"],
    "moduleNameMapper": {
      "^ioredis$": "<rootDir>/tests/helpers/redis-mock.js"
    },
    "testTimeout": 30000
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.7",
    "mongoose": "^8.4.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "sharp": "^0.33.4",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.4",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
