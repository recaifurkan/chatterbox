# =============================================================================
#  Chatterbox Backend — Local Development Environment
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  For Docker Compose deployment use the root .env.example instead.
# =============================================================================

NODE_ENV=development
PORT=5000
INSTANCE_ID=local_dev

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local dev: start MongoDB via  docker compose up -d mongodb
MONGODB_URI=mongodb://localhost:27017/chatterboxdb

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev: start Redis via  docker compose up -d redis
# If Redis has a password: redis://:yourpassword@localhost:6379
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32_at_least_32_chars
JWT_REFRESH_SECRET=change_me_generate_another_openssl_rand_hex_32_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# RFC-1918 private IPs and localhost are always allowed automatically.
# Extra origins (comma-separated): CORS_ORIGINS=http://192.168.1.50:3000
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=

# ── MinIO (S3-uyumlu nesne deposu) ───────────────────────────────────────────
# Local dev: start MinIO via  docker compose up -d minio
# Docker Compose deployment: MINIO_ENDPOINT=minio  (service name)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=chatterbox_minio
MINIO_SECRET_KEY=change_me_strong_minio_secret_key
MINIO_BUCKET=chatterbox-uploads

# ── File Upload ───────────────────────────────────────────────────────────────
# Max file size in bytes (default: 25 MB)
MAX_FILE_SIZE=26214400

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── LiveKit (WebRTC SFU — multi-server) ───────────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
# Number of LiveKit servers running locally (default: 2)
LIVEKIT_SERVER_COUNT=2
# Client URL is derived from CLIENT_URL (http → ws, https → wss)
# Nginx routes /livekit/<id>/ to the correct server

